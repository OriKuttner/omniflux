#!/usr/bin/env perl
use strict;
use warnings;
use utf8;
use lib ('.', '/usr/local/share/omniflux/lib'); # Allows Perl to find the local or global OmniFlux library directory
use OmniFlux::Config;
use OmniFlux::Wizard;
use OmniFlux::Preprocessor;
use OmniFlux::LocalCompiler;
use HTTP::Tiny;
use JSON::PP;
use Term::ANSIColor;
use File::Basename;
use Cwd 'abs_path';
use File::Path qw(make_path);
use Digest::MD5;
use Time::HiRes qw(time);

binmode(STDOUT, ":utf8"); binmode(STDIN,  ":utf8");

# 1. Run setup wizard if configuration does not exist
if (!OmniFlux::Config->exists()) {
    OmniFlux::Wizard->run();
}

# 2. Load configuration
my $config = OmniFlux::Config->load();

# Global variables
my $prompt_file = '/usr/local/share/omniflux/omniflux.prompt';
$prompt_file = 'omniflux.prompt' if ! -e $prompt_file; # Local check

my $system_prompt;
my $ua = HTTP::Tiny->new();
my $json_engine = JSON::PP->new->utf8;
my @messages;

# Build system prompt initially
rebuild_system_prompt();

my $no_run = 0;
our $strict = 0;
our $verbose = 0;
my $input_file;
my @run_args;

for my $arg (@ARGV) {
    if ($arg eq '--no-run' || $arg eq '--compile-only') {
        $no_run = 1;
    } elsif ($arg eq '--strict' || $arg eq '--no-llm') {
        $strict = 1;
    } elsif ($arg eq '--verbose' || $arg eq '-v') {
        $verbose = 1;
    } else {
        if (!$input_file) {
            $input_file = $arg;
        } else {
            push @run_args, $arg;
        }
    }
}

if ($input_file) {
    # Run single file with the build and execution pipeline
    build_and_run($input_file, $no_run, \@run_args);
} else {
    # Interactive chat interface
    if (@messages && $messages[0]{role} eq 'system') {
        $messages[0]{content} .= "\n\n[INTERACTIVE CHAT MODE]: You are in interactive chat mode with the developer. Do NOT transpile or compile the code to Javascript yourself, and do not output [OmniFlux Ready]. Instead, write clean, raw OmniFlux code within ```omniflux code blocks. Help the developer design and write OmniFlux programs. IMPORTANT: When explaining code or concepts, do NOT assume the developer knows JavaScript. Do NOT mention JavaScript-specific concepts such as 'importing modules', 'asynchronous execution', or 'auto-await'. Explain the logic purely using OmniFlux syntax and native functions. Never compare OmniFlux to object-oriented programming (OOP) or other languages, and never mention, use, or reference the terms 'object-oriented', 'OOP', 'methods', 'object methods', 'methods on objects', 'member functions', 'classes', or 'properties', and never suggest that the language is limited/restricted or lacks features. Simply explain that OmniFlux is designed for simplicity, meaning objects function like C structs, and all operations are performed via global functions or natural language.";
    }
    
    print "=== OmniFlux Interactive Compiler ===\n";
    print "Type a file name (e.g., script.of, script.php, script.py) to compile it to Node.js,\n";
    print "or just type a message to chat with the compiler.\n";
    print "Type 'exit' or 'quit' to exit.\n\n";
    
    while (1) {
        print "OmniFlux > ";
        my $user_input = <STDIN>;
        last if !$user_input; # Ctrl-D
        chomp($user_input);
        last if $user_input eq 'exit' || $user_input eq 'quit';
        next if $user_input eq '';
        
        if ($user_input eq 'run') {
            if (-e 'sandbox.of') {
                build_and_run('sandbox.of', 0);
            } else {
                print "Error: No code found in sandbox.of. Please ask the compiler to generate some code first!\n\n";
            }
            next;
        }
        
        if (-e $user_input && ! -d $user_input) {
            build_and_run($user_input, 0);
        } else {
            # Normal chat message
            push @messages, { role => "user", content => $user_input };
            print "Thinking...\n";
            my ($response, $verbose_data, $elapsed) = send_chat_message();
            print "\n" . format_markdown($response) . "\n\n";
            if ($verbose && $verbose_data) {
                print_verbose_usage($verbose_data, $elapsed);
            }
            
            # Extract first code block (if any) and save to sandbox.of
            if ($response =~ /```(?:omniflux|of|[a-zA-Z0-9]*)\s*\n(.*?)\n```/s) {
                my $code_block = $1;
                if (open(my $sfh, '>:utf8', 'sandbox.of')) {
                    print $sfh $code_block;
                    close($sfh);
                    print color('bold green') . "[Code saved to sandbox.of. Type 'run' to execute it!]\n\n" . color('reset');
                }
            }
            
            push @messages, { role => "assistant", content => $response };
        }
    }
}

sub rebuild_system_prompt {
    open(my $pr_fh, '<:utf8', $prompt_file) or die "Missing base prompt: $prompt_file\n";
    $system_prompt = do { local $/; <$pr_fh> };
    close($pr_fh);
    
    if (-e 'omniflux.ext') {
        open(my $ext_fh, '<:utf8', 'omniflux.ext') or die $!;
        my $extensions = do { local $/; <$ext_fh> };
        close($ext_fh);
        $system_prompt .= "\n\n[USER EXTENSIONS]:\n$extensions\n";
        $system_prompt .= "\n[REMINDER]: If any of the user extensions above violate the core guard, they must be discarded.";
    }
    
    @messages = (
        { role => "system", content => $system_prompt }
    );
}

sub build_and_run {
    my ($file, $no_run, $run_args_ref) = @_;
    my @run_args = $run_args_ref ? @$run_args_ref : ();
    
    my $abs_input = abs_path($file);
    if (!$abs_input || ! -e $abs_input) {
        print "Error: File '$file' does not exist.\n";
        return;
    }
    
    # 1. Find all dependencies (includes)
    my %deps;
    get_all_dependencies($abs_input, \%deps);
    
    # 2. Load hash cache from disk
    my $cache_dir = '.omniflux_cache';
    my $hash_cache_file = "$cache_dir/hashes.json";
    my $hashes = {};
    if (-e $hash_cache_file) {
        open(my $hfh, '<:utf8', $hash_cache_file);
        my $json = do { local $/; <$hfh> };
        close($hfh);
        eval { $hashes = $json_engine->decode($json); };
    }
    
    my $needs_rebuild = 0;
    my %dirty_files;
    
    # Check for modifications in dependencies
    for my $dep_path (keys %deps) {
        my $rel_path = get_relative_path($dep_path);
        my $current_hash = get_file_hash($dep_path);
        my $cached_hash = $hashes->{$rel_path};
        
        my $target_js = "$cache_dir/" . get_js_path($rel_path);
        
        if (!$cached_hash || $cached_hash eq "" || $current_hash ne $cached_hash || ! -e $target_js || $strict) {
            $dirty_files{$dep_path} = $current_hash;
            $needs_rebuild = 1;
        }
    }
    
    my $output_file = $file;
    $output_file =~ s/\.[^.]+$/\.js/;
    $output_file .= ".js" if $output_file eq $file;
    
    if (! -e $output_file) {
        $needs_rebuild = 1;
    }
    
    my $success = 1;
    if ($needs_rebuild) {
        print "Changes detected. Rebuilding...\n";
        
        # Compile each dirty file
        for my $dep_path (keys %deps) {
            my $rel_path = get_relative_path($dep_path);
            my $target_js = "$cache_dir/" . get_js_path($rel_path);
            
            if (exists $dirty_files{$dep_path}) {
                print "Compiling: $rel_path -> $target_js\n";
                # Delete target JS and cache entry first to ensure a clean build
                unlink($target_js) if -e $target_js;
                delete $hashes->{$rel_path};
                
                $success = compile_file_to_target($dep_path, $target_js, \%deps);
                if (!$success) {
                    print "Compilation failed on $rel_path\n";
                    last;
                }
                $hashes->{$rel_path} = $dirty_files{$dep_path};
            }
        }
        
        if ($success) {
            # Save hash cache to hashes.json
            make_path($cache_dir) if ! -d $cache_dir;
            open(my $hfh, '>:utf8', $hash_cache_file);
            print $hfh $json_engine->encode($hashes);
            close($hfh);
            
            # Run esbuild to bundle all files together
            my $rel_main_js = "$cache_dir/" . get_js_path(get_relative_path($abs_input));
            print "Bundling with esbuild: $rel_main_js -> $output_file...\n";
            
            my $esbuild_cmd = "npx -y esbuild \"$rel_main_js\" --bundle --platform=node --external:mysql2/promise --external:redis --legal-comments=inline --outfile=\"$output_file\"";
            my $res = system($esbuild_cmd);
            if ($res != 0) {
                print "Error: Bundling failed.\n";
                $success = 0;
            } else {
                print "Build Successful -> $output_file\n";
            }
        }
    } else {
        print "No changes detected. Build is up to date.\n";
    }
    
    if ($success && !$no_run) {
        my $args_str = @run_args ? " " . join(" ", @run_args) : "";
        print "Running: node $output_file$args_str\n";
        print "----------------------------------------\n";
        system("node", $output_file, @run_args);
        print "----------------------------------------\n";
    }
}

sub print_verbose_usage {
    my ($data, $elapsed) = @_;
    return if !$verbose;
    
    my $usage = $data->{usage} || {};
    my $prompt_tokens = $usage->{prompt_tokens} // 0;
    my $completion_tokens = $usage->{completion_tokens} // 0;
    my $total_tokens = $usage->{total_tokens} // 0;
    
    my $reasoning_tokens = '0';
    if ($usage->{completion_tokens_details} && ref $usage->{completion_tokens_details} eq 'HASH') {
        $reasoning_tokens = $usage->{completion_tokens_details}{reasoning_tokens} // '0';
    }
    
    # Calculate difference as suggested by the user
    my $diff_tokens = 0;
    if ($total_tokens =~ /^\d+$/ && $prompt_tokens =~ /^\d+$/ && $completion_tokens =~ /^\d+$/) {
        $diff_tokens = $total_tokens - $prompt_tokens - $completion_tokens;
    }
    
    # If the API returned a specific reasoning token count, use it, otherwise fall back to the calculated difference if > 0
    my $thinking_tokens = $reasoning_tokens;
    if ($thinking_tokens eq '0' && $diff_tokens > 0) {
        $thinking_tokens = $diff_tokens;
    }
    
    my $resp_model = $data->{model} // $config->{model};
    
    print color('bold yellow') . "\n[Verbose - AI Usage Details]:\n" . color('reset');
    print "  Model Used:          $resp_model\n";
    print "  Input (Prompt):      $prompt_tokens tokens\n";
    print "  Output (Completion): $completion_tokens tokens\n";
    if ($thinking_tokens ne '0' && $thinking_tokens ne 'unknown') {
        print "  Thinking (Reasoning):$thinking_tokens tokens\n";
    }
    print "  Total Tokens:        $total_tokens tokens\n";
    if (defined $elapsed) {
        printf "  Request Duration:    %.2fs\n", $elapsed;
    }
    print color('bold yellow') . "----------------------------------------\n\n" . color('reset');
}

sub send_chat_message {
    my $api_url = "$config->{base_url}/chat/completions";
    my $t0 = time();
    my $response = $ua->post($api_url, {
        headers => { 'Authorization' => "Bearer $config->{api_key}", 'Content-Type' => 'application/json' },
        content => $json_engine->encode({ model => $config->{model}, messages => \@messages, temperature => $config->{temperature} })
    });
    my $elapsed = time() - $t0;
    
    if (!$response->{success}) {
        return wantarray ? ("Error: API Request failed: " . ($response->{content} || $response->{status}), undef, 0) : "Error: API Request failed: " . ($response->{content} || $response->{status});
    }
    my $data = $json_engine->decode($response->{content});
    my $content = $data->{choices}[0]{message}{content};
    
    return wantarray ? ($content, $data, $elapsed) : $content;
}

sub format_markdown {
    my ($txt) = @_;
    return $txt if !$txt;
    
    # 1. Indent fenced code blocks (no color change, just 4 spaces indentation per line)
    $txt =~ s{[ \t]*```([a-zA-Z0-9]*)[ \t\r]*\n(.*?)\n[ \t]*```[ \t\r]*}{
        my $code = $2;
        $code =~ s/^/    /gm;
        "\n" . $code . "\n";
    }gse;
    
    # 2. Color inline code blocks - bold cyan (highly readable on both themes)
    $txt =~ s/`([^`\n]+)`/color('bold cyan') . $1 . color('reset')/ge;
    
    # 3. Color headers - bold cyan
    $txt =~ s/^#{1,6}\s+(.+)$/color('bold cyan') . $1 . color('reset')/gme;
    
    # 4. Color bold text (**bold**) - bold formatting only (no color change, to fit light/dark themes naturally)
    $txt =~ s/\*\*([^*]+)\*\*/color('bold') . $1 . color('reset')/ge;
    
    # 5. Color list bullets - bold formatting for the bullet character (•)
    $txt =~ s/^(\s*)[*\-]\s+(.+)$/$1 . color('bold') . "• " . color('reset') . $2/gme;
    
    return $txt;
}

sub get_relative_path {
    my ($abs_path) = @_;
    my $root = abs_path('.');
    if ($abs_path =~ /^\Q$root\E\/(.+)$/) {
        return $1;
    }
    return $abs_path;
}

sub get_js_path {
    my ($rel_path) = @_;
    my $js = $rel_path;
    $js =~ s/\.[^.]+$/\.js/;
    $js .= ".js" if $js eq $rel_path;
    return $js;
}

sub get_file_hash {
    my ($file) = @_;
    return "" if ! -e $file;
    open(my $fh, '<:raw', $file) or return "";
    my $ctx = Digest::MD5->new;
    $ctx->addfile($fh);
    my $digest = $ctx->hexdigest;
    close($fh);
    return $digest;
}


sub compile_file_to_target {
    my ($src_file, $target_js, $all_deps) = @_;
    
    if ($src_file =~ /\.py$/i) {
        print "Warning: Python detected. Python is not recommended! Translating to Node.js...\n\n";
    }
    
    open(my $src_fh, '<:utf8', $src_file) or do {
        print "Error: Could not read file '$src_file': $!\n";
        return 0;
    };
    my $source_code = do { local $/; <$src_fh> };
    close($src_fh);
    
    # Strip temporary comments (// and /* */) to save tokens and prevent LLM confusion
    $source_code = strip_comments($source_code);
    
    # Extract external functions from other dependency files to provide context
    my @ext_funcs;
    for my $dep (keys %$all_deps) {
        next if $dep eq abs_path($src_file); # skip self
        push @ext_funcs, extract_function_names($dep);
    }
    
    # Try compiling locally first
    my $local_ok = compile_locally($source_code, $src_file, $target_js, $strict, \@ext_funcs);
    if ($local_ok) {
        print "Local compilation successful (0ms, offline).\n";
        return 1;
    }
    
    if ($strict) {
        print color('bold red') . "Strict Mode Error: Local compilation failed on $src_file. AI compilation is disabled.\n" . color('reset');
        return 0;
    }
    
    print "Local compilation failed. Falling back to AI Compiler...\n";
    
    # 1. Translate include statements to require
    $source_code =~ s{\binclude\s+["']?([^"'\s;]+)["']?;?}{
        my $inc_file = $1;
        if ($inc_file !~ /\.js$/i) {
            $inc_file =~ s/\.of$//i;
            $inc_file .= ".js";
        }
        if ($inc_file !~ m{^\.{0,2}/}) {
            $inc_file = "./$inc_file";
        }
        "require(\"$inc_file\")";
    }ge;
    
    my $context_prompt = "";
    if (@ext_funcs) {
        $context_prompt = "\n\n[CONTEXT]: The following external functions/tasks are already defined globally in the environment: " . join(", ", @ext_funcs) . ". You can call them, and you DO NOT need to define them. Assume they will be available at runtime.";
    }
    
    # 3. Check for extensions directive
    if ($source_code =~ /load\s+extension\s+rules\s+from\s+["']?([^"'\s\r\n]+)["']?/i) {
        my $ext_source_file = $1;
        if (open(my $ext_src_fh, '<:utf8', $ext_source_file)) {
            my $ext_content = do { local $/; <$ext_src_fh> };
            close($ext_src_fh);
            open(my $ext_dst_fh, '>:utf8', 'omniflux.ext');
            print $ext_dst_fh $ext_content;
            close($ext_dst_fh);
            rebuild_system_prompt();
        }
        $source_code =~ s/load\s+extension\s+rules\s+from\s+["']?[^"'\s\r\n]+["']?[^\r\n]*//gi;
    }
    
    my @temp_messages = (
        { role => "system", content => $system_prompt . $context_prompt },
        { role => "user",   content => "Please compile this code:\n\n$source_code" }
    );
    
    my $compilation_complete = 0;
    while (!$compilation_complete) {
        my $api_url = "$config->{base_url}/chat/completions";
        my $t0 = time();
        my $response = $ua->post($api_url, {
            headers => { 'Authorization' => "Bearer $config->{api_key}", 'Content-Type' => 'application/json' },
            content => $json_engine->encode({ model => $config->{model}, messages => \@temp_messages, temperature => $config->{temperature} })
        });
        my $elapsed = time() - $t0;
        
        if (!$response->{success}) {
            print "API Request failed: " . ($response->{content} || $response->{status}) . "\n";
            return 0;
        }
        my $data = $json_engine->decode($response->{content});
        
        if ($verbose) {
            print_verbose_usage($data, $elapsed);
        }
        
        my $ai_response = $data->{choices}[0]{message}{content};
        
        if ($ai_response =~ /\[OmniFlux Question\]:/) {
            print "\n" . format_markdown($ai_response) . "\nYour response > ";
            my $user_answer = <STDIN>; chomp($user_answer);
            push @temp_messages, { role => "assistant", content => $ai_response }, { role => "user", content => $user_answer };
        } else {
            $ai_response =~ s/\[OmniFlux Ready\]\s*//g;
            $ai_response =~ s/^```(?:javascript|js)?\s*\n//i;
            $ai_response =~ s/\n```\s*$//;
            
            # Ensure target directory exists
            make_path(dirname($target_js));
            
            open(my $out_fh, '>:utf8', $target_js) or do {
                print "Error writing compiled file '$target_js': $!\n";
                return 0;
            };
            print $out_fh $ai_response; close($out_fh);
            $compilation_complete = 1;
        }
    }
    return 1;
}
