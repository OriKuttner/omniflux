          changed = true;
          break;
        }
      }
      if (changed) {
        print("\nChange detected. Rebuilding...");
        let new_result = await build_once(input_file, compile_only);
        if (new_result.ok) {
          output_file = new_result.output;
          if (!compile_only) {
            await exec(output_file + " &");
          }
        } else {
          print("Rebuild failed. Waiting for fixes...");
        }
        deps = await get_all_dependencies(abs_input, null);
        mod_times = {};
        for (let dep_path2 of deps) {
          let stat3 = filestat(dep_path2);
          if (stat3) {
