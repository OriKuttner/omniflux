      await new Promise((resolve) => setTimeout(resolve, 1 * 1e3));
      let changed = false;
      for (let dep_path of deps) {
        if (!fileexists(dep_path)) {
          changed = true;
          break;
        }
        let stat2 = filestat(dep_path);
