// compiler/omniflux.of
// Entry point for the OmniFlux bootstrap compiler.
// Usage:
//   omniflux <file.of> [--compile-only] [--strict] [--watch] [-- args...]
//
// Pipeline:
//   1. Parse CLI arguments
//   2. Resolve all dependencies via preprocessor
//   3. Strip comments
//   4. Validate syntax (bracket matching)
//   5. Prescan user-defined tasks for async awareness
//   6. Transpile each file to JavaScript
//   7. Bundle with esbuild
//   8. Run the output (unless --compile-only)

$VERSION = "1.0.4"

include "compiler/bundler.of"
include "compiler/validator.of"
include "compiler/transpiler.of"
include "compiler/symbols.of"
include "stdlib/system.of"
include "stdlib/network.of"

// ---------------------------------------------------------------------------
// CLI argument parsing
// ---------------------------------------------------------------------------
define task parse_args(argv) {
    var result = {
        input_file: "",
        compile_only: false,
        strict: false,
        watch: false,
        setup: false,
        help: false,
        verbose: false,
        force: false,
        version: false,
        run_args: []
    };
    var after_dashdash = false
    for arg of argv {
        if after_dashdash {
            arraypush(result.run_args, arg)
        } else if arg == "--" {
            after_dashdash = true
        } else if arg == "--compile-only" || arg == "--no-run" {
            result.compile_only = true
        } else if arg == "--strict" || arg == "--no-llm" {
            result.strict = true
        } else if arg == "--watch" || arg == "-w" {
            result.watch = true
        } else if arg == "--setup" || arg == "--config" {
            result.setup = true
        } else if arg == "--help" || arg == "-h" {
            result.help = true
        } else if arg == "--version" {
            result.version = true
        } else if arg == "--verbose" || arg == "-v" {
            result.verbose = true
        } else if arg == "--force" || arg == "-f" {
            result.force = true
        } else if result.input_file == "" {
            result.input_file = arg
        } else {
            arraypush(result.run_args, arg)
        }
    }
    if result.input_file != "" {
        if !match(result.input_file, "/\\.of$/i") {
            result.input_file = result.input_file + ".of"
        }
    }
    return result
}

// ---------------------------------------------------------------------------
// print_usage: show help text when no file is given
// ---------------------------------------------------------------------------
define task print_usage() {
    print("Usage: omniflux <file.of> [options] [-- args...]")
    print("")
    print("Options:")
    print("  -h, --help       Show this help information")
    print("  --version        Show compiler version")
    print("  -v, --verbose    Print detailed AI usage statistics")
    print("  -f, --force      Force rebuild even if output is up-to-date")
    print("  --compile-only   Compile only, do not run the output")
    print("  --strict         Fail if compilation requires AI assistance")
    print("  --watch          Watch for changes and rebuild automatically")
    print("  --setup / --config Run the interactive setup wizard to configure the API key")
    print("  --               Pass remaining arguments to the compiled program")
}

// ---------------------------------------------------------------------------
// config_path: returns path to ~/.omnifluxrc
// ---------------------------------------------------------------------------
define task config_path() {
    var home = getenv("HOME")
    return home + "/.omnifluxrc"
}

// ---------------------------------------------------------------------------
// config_exists: returns true if config file exists
// ---------------------------------------------------------------------------
define task config_exists() {
    return fileexists(config_path())
}

// ---------------------------------------------------------------------------
// config_load: reads and parses ~/.omnifluxrc
// ---------------------------------------------------------------------------
define task config_load() {
    var raw = fileread(config_path())
    return jsonparse(raw)
}

// ---------------------------------------------------------------------------
// config_save: writes config object to ~/.omnifluxrc
// ---------------------------------------------------------------------------
define task config_save(cfg) {
    filewrite(config_path(), jsonencode(cfg, true))
}

// ---------------------------------------------------------------------------
// run_wizard: interactive setup wizard for first-time users
// ---------------------------------------------------------------------------
define task run_wizard() {
    print("=== Welcome to OmniFlux ===")
    print("To use the AI Compiler features, you need an API key from the developer portal.")
    print("If you do not have a key, please sign up and get one at:")
    print("👉 https://omniflux.helicontech.co.il")
    print("")
    
    var api_key = input("Enter your OmniFlux API key: ")
    if api_key == "" {
        print("Error: API key required.")
        exit(1)
    }

    var cfg = {
        api_key: api_key
    }
    config_save(cfg)
    print("\n[OmniFlux Setup]: Successfully configured!\n")
    return cfg
}

// ---------------------------------------------------------------------------
// send_ai_request: sends messages to the AI API and returns the response text
// ---------------------------------------------------------------------------
define task send_ai_request(cfg, messages) {
    var url = "https://omniflux.helicontech.co.il/v1/chat/completions"
    var body = { messages: messages, temperature: 0.2 }
    var headers = { "Authorization": "Bearer " + cfg.api_key }
    
    var t0 = 0
    @{ t0 = Date.now(); @}
    
    var response = networkpost(url, body, headers)
    
    var elapsed = 0
    @{ elapsed = (Date.now() - t0) / 1000; @}
    
    var err_msg = null
    if !response || !response.choices {
        @{
            if (response && response.error) {
                err_msg = typeof response.error === 'object' ? response.error.message : response.error;
            }
        @}
        if err_msg {
            print("API Error: %s", err_msg)
        }
        return null
    }
    
    cfg.last_verbose_data = response
    cfg.last_elapsed = elapsed
    
    return response.choices[0].message.content
}

// ---------------------------------------------------------------------------
// print_verbose_usage: displays token counts and latency details
// ---------------------------------------------------------------------------
define task print_verbose_usage(data, elapsed) {
    var usage = data.usage
    if usage == null {
        usage = {}
    }
    var prompt_tokens = usage.prompt_tokens
    if prompt_tokens == null {
        prompt_tokens = 0
    }
    
    var completion_tokens = usage.completion_tokens
    if completion_tokens == null {
        completion_tokens = 0
    }
    
    var total_tokens = usage.total_tokens
    if total_tokens == null {
        total_tokens = 0
    }
    
    var reasoning_tokens = 0
    if usage.completion_tokens_details != null {
        if usage.completion_tokens_details.reasoning_tokens != null {
            reasoning_tokens = usage.completion_tokens_details.reasoning_tokens
        }
    }
    
    var diff_tokens = total_tokens - prompt_tokens - completion_tokens
    var thinking_tokens = reasoning_tokens
    if thinking_tokens == 0 && diff_tokens > 0 {
        thinking_tokens = diff_tokens
    }
    
    var resp_model = data.model
    if resp_model == null {
        resp_model = "unknown"
    }
    
    print("\x1b[1;33m\n[Verbose - AI Usage Details]:\x1b[0m")
    print("  Model Used:          " + resp_model)
    print("  Input (Prompt):      " + prompt_tokens + " tokens")
    print("  Output (Completion): " + completion_tokens + " tokens")
    if thinking_tokens != 0 {
        print("  Thinking (Reasoning):" + thinking_tokens + " tokens")
    }
    print("  Total Tokens:        " + total_tokens + " tokens")
    print(sprintf("  Request Duration:    %.2fs", elapsed))
    print("\x1b[1;33m----------------------------------------\n\x1b[0m")
}

// ---------------------------------------------------------------------------
// format_chat_response: basic markdown formatting for terminal output
// ---------------------------------------------------------------------------
define task format_chat_response(txt) {
    if !txt {
        return ""
    }
    // Strip fenced code block markers and indent content
    txt = strreplace(txt, "/```[a-zA-Z0-9]*\\n([\\s\\S]*?)\\n```/gm", "\n$1\n")
    // Bold: **text**
    txt = strreplace(txt, "/\\*\\*([^*]+)\\*\\*/g", "$1")
    // Headers: ## text
    txt = strreplace(txt, "/^#{1,6}\\s+(.+)$/gm", "$1")
    return txt
}

// ---------------------------------------------------------------------------
// read_system_prompt: loads the OmniFlux system prompt file
// ---------------------------------------------------------------------------
define task read_system_prompt() {
    # The system prompt is managed on the server side to avoid double sending and ensure a single source of truth.
    return ""
}

// ---------------------------------------------------------------------------
// detect_missing_includes: scans source code to find missing stdlib includes
// ---------------------------------------------------------------------------
define task detect_missing_includes(source_code) {
    var missing = []
    
    // Check encrypt/base64
    if match(source_code, "/\\b(encrypt|decrypt|base64_encode|base64encode|base64_decode|base64decode)\\b/") {
        if !match(source_code, "/stdlib\\/encrypt\\.of/") {
            arraypush(missing, "stdlib/encrypt.of")
        }
    }
    
    // Check network
    if match(source_code, "/\\b(networkget|networkpost|uploadfile|upload_file)\\b/") {
        if !match(source_code, "/stdlib\\/network\\.of/") {
            arraypush(missing, "stdlib/network.of")
        }
    }

    // Check datetime
    if match(source_code, "/\\b(datetime_now|datetime_format)\\b/") {
        if !match(source_code, "/stdlib\\/datetime\\.of/") {
            arraypush(missing, "stdlib/datetime.of")
        }
    }

    // Check mysql
    if match(source_code, "/\\b(mysqlconnect|mysql_connect|mysqlquery|mysql_query|mysqlclose|mysql_close)\\b/") {
        if !match(source_code, "/stdlib\\/mysql\\.of/") {
            arraypush(missing, "stdlib/mysql.of")
        }
    }

    return missing
}

// ---------------------------------------------------------------------------
// ai_compile_file: send source to AI and write compiled JS to target path
// ---------------------------------------------------------------------------
define task ai_compile_file(cfg, src_path, target_js, runtime_error = null) {
    var source_code = fileread(src_path)
    var missing_libs = detect_missing_includes(source_code)
    
    source_code = strip_comments(source_code)

    // Replace include statements with require
    source_code = strreplace(source_code, "/\\binclude\\s+[\"']?([^\\.\"'\\s;]+(?:\\.[a-z]+)?)[\"']?/g", "require('./$1')")

    print("Falling back to AI Compiler...")

    var prompt_addition = ""
    if len(missing_libs) > 0 {
        var lib_list = arrayjoin(missing_libs, ", ")
        prompt_addition = "\n\nNOTE: The code uses functions from the following standard libraries but is missing their include statements: " + lib_list + ".\nYou MUST prepend the appropriate include directive(s) (e.g. include \"" + missing_libs[0] + "\") to the top of the OmniFlux source code, and you MUST return BOTH the [OmniFlux Source] block (containing the healed OmniFlux code) and the [OmniFlux Ready] block (containing the compiled JavaScript code)."
    }
    if runtime_error != null && runtime_error != "" {
        prompt_addition = prompt_addition + "\n\nCRITICAL: A compiler/runtime error occurred when executing this code:\n" + runtime_error + "\nPlease fix this error in the OmniFlux code (such as adding missing include statements, fixing variables, typos, missing 'ref' keywords, or syntax errors). You MUST return BOTH the [OmniFlux Source] block (containing the healed OmniFlux code) and the [OmniFlux Ready] block (containing the compiled JavaScript code)."
    }

    var messages = [
        { role: "user",   content: "Please compile this code:" + prompt_addition + "\n\n" + source_code }
    ]

    var done = false
    while !done {
        print("Thinking...")
        var ai_response = send_ai_request(cfg, messages)
        if ai_response == null {
            print("Error: AI request failed.")
            return false
        }

        if match(ai_response, "/\\[OmniFlux Question\\]:/") {
            print("%s", format_chat_response(ai_response))
            if cfg.verbose {
                print_verbose_usage(cfg.last_verbose_data, cfg.last_elapsed)
            }
            var user_answer = input("Your response > ")
            arraypush(messages, { role: "assistant", content: ai_response })
            arraypush(messages, { role: "user", content: user_answer })
        } else {
            # Extract updated OmniFlux source if [OmniFlux Source] is present
            var updated_source = null
            @{
                const source_marker = "[OmniFlux Source]";
                const ready_marker = "[OmniFlux Ready]";
                const s_idx = ai_response.indexOf(source_marker);
                const r_idx = ai_response.indexOf(ready_marker);
                if (s_idx !== -1 && r_idx !== -1 && s_idx < r_idx) {
                    let content = ai_response.substring(s_idx + source_marker.length, r_idx).trim();
                    // Remove markdown code blocks if present
                    content = content.replace(/^```(?:omniflux|of|[a-zA-Z0-9]*)\s*\n/i, "");
                    content = content.replace(/\n```\s*$/, "");
                    updated_source = content;
                }
            @}

            if updated_source != null && updated_source != "" {
                var original_len = len(source_code)
                var updated_len = len(updated_source)

                var is_suspicious = false
                if original_len > 100 {
                    if updated_len < original_len * 0.85 {
                        is_suspicious = true
                    }
                }

                var orig_has_start = match(source_code, "/\\bon\\s+start\\b/i")
                var upd_has_start = match(updated_source, "/\\bon\\s+start\\b/i")
                if orig_has_start && !upd_has_start {
                    is_suspicious = true
                }

                if is_suspicious {
                    print("\x1b[1;31m[OmniFlux Compiler Warning]: AI healed code is suspiciously shorter than the original file (%d vs %d chars) or missing key blocks. Skipping automatic source file overwrite to prevent truncation.\x1b[0m", original_len, updated_len)
                } else {
                    @{
                        try {
                            require('fs').copyFileSync(src_path, src_path + ".bak");
                        } catch (e) {}
                    @}
                    filewrite(src_path, updated_source)
                    print("\x1b[1;32m[Source file '%s' automatically updated/healed by AI! (Backup saved to .bak)]\x1b[0m", pathbasename(src_path))
                    if cfg != null {
                        cfg.was_healed = true
                    }
                }
            }

            // Strip wrapper markers from the JS code
            var js_code = ai_response
            @{
                {
                    const ready_marker = "[OmniFlux Ready]";
                    const r_idx = ai_response.indexOf(ready_marker);
                    if (r_idx !== -1) {
                        js_code = ai_response.substring(r_idx + ready_marker.length).trim();
                    }
                }
            @}

            js_code = strreplace(js_code, "/^```(?:javascript|js)?\\s*\\n/i", "")
            js_code = strreplace(js_code, "/\\n```\\s*$/", "")

            var dir = pathdirname(target_js)
            dircreate(dir)
            filewrite(target_js, js_code)
            done = true
            if cfg.verbose {
                print_verbose_usage(cfg.last_verbose_data, cfg.last_elapsed)
            }
        }
    }
    return true
}

// ---------------------------------------------------------------------------
// interactive_chat: runs the interactive chat REPL
// ---------------------------------------------------------------------------
define task interactive_chat(cfg) {
    var messages = []

    print("=== OmniFlux Interactive Compiler ===")
    print("Type a file name (e.g., script.of) to compile it,")
    print("or just type a message to chat with the compiler.")
    print("Type 'exit' or 'quit' to exit.")
    print("")

    while true {
        var user_input = input("OmniFlux > ")
        if user_input == null || user_input == "" {
            continue
        }
        if user_input == "exit" || user_input == "quit" {
            break
        }
        if user_input == "run" {
            if fileexists("sandbox.of") {
                var br = build_once("sandbox.of", false, false, cfg)
                if br.ok {
                    var chat_out = system(br.output)
                    printf("%s", chat_out)
                }
            } else {
                print("Error: No code found in sandbox.of. Please ask the compiler to generate some code first!")
                print("")
            }
            continue
        }
        if fileexists(user_input) {
            var fbr = build_once(user_input, false, false, cfg)
            if fbr.ok {
                var fout = system(fbr.output)
                printf("%s", fout)
            }
            continue
        }

        arraypush(messages, { role: "user", content: user_input })
        print("Thinking...")
        var response = send_ai_request(cfg, messages)
        if response == null {
            print("Error: AI request failed.")
            continue
        }

        print("")
        print("%s", format_chat_response(response))
        print("")

        // Save first code block to sandbox.of
        var code_m = match(response, "/```(?:omniflux|of|[a-zA-Z0-9]*)\\s*\\n([\\s\\S]*?)\\n```/")
        var code_saved = false
        if code_m {
            filewrite("sandbox.of", code_m[0])
            code_saved = true
        }
        if code_saved {
            print("\x1b[1;32m[Code saved to sandbox.of. Type 'run' to execute it!]\x1b[0m")
            print("")
        }

        if cfg.verbose {
            print_verbose_usage(cfg.last_verbose_data, cfg.last_elapsed)
        }

        arraypush(messages, { role: "assistant", content: response })
    }
}

// ---------------------------------------------------------------------------
// read_runtime: loads runtime.js from the OmniFlux library directory
// ---------------------------------------------------------------------------
define task read_runtime() {
    var parent_dir = pathdirname(scriptdir())
    var candidates = [
        pathjoin(scriptdir(), "runtime.js"),
        pathjoin(scriptdir(), "OmniFlux/runtime.js"),
        pathjoin(parent_dir, "runtime.js"),
        pathjoin(parent_dir, "OmniFlux/runtime.js"),
        "/usr/local/share/omniflux/runtime.js",
        "/usr/local/share/omniflux/OmniFlux/runtime.js",
        "/usr/share/omniflux/runtime.js",
        "/usr/share/omniflux/OmniFlux/runtime.js"
    ]
    for path of candidates {
        if fileexists(path) {
            return fileread(path)
        }
    }
    print("Error: Cannot find OmniFlux runtime.js")
    exit(1)
}

// ---------------------------------------------------------------------------
// compile_file: strip → validate → prescan → transpile for a single file
// ---------------------------------------------------------------------------
define task compile_file(abs_path, runtime_js, global_user_tasks) {
    var raw = fileread(abs_path)
    var filename = pathbasename(abs_path)

    // Strip comments
    var content = strip_comments(raw)

    // Validate bracket structure
    var vresult = validate(content, filename)
    if !vresult.ok {
        print("Compilation Error in %s:", filename)
        print("%s", vresult.error)
        return null
    }

    // Prescan tasks in this file and merge into global table
    var file_tasks = prescan_tasks(content)
    @{ Object.assign(global_user_tasks, file_tasks); @}

    // Transpile
    var user_task_keys = @{ Object.keys(global_user_tasks) @}
    var tresult = transpile(content, abs_path, global_user_tasks, runtime_js)
    if !tresult.ok {
        print("Transpile Error in %s:", filename)
        print("%s", tresult.error)
        return null
    }

    return tresult.js
}

// ---------------------------------------------------------------------------
// build_once: full build pipeline for a given entry file
// Returns: { ok, output_file } or { ok: false, error }
// ---------------------------------------------------------------------------
define task build_once(input_file, compile_only, strict, cfg, force) {
    var start_time = 0
    @{ start_time = Date.now(); @}
    var abs_input = pathresolve(input_file)

    if !fileexists(abs_input) {
        print("Error: File '%s' does not exist.", input_file)
        return { ok: false }
    }

    // Collect all dependencies in order
    var deps = get_all_dependencies(abs_input, null)

    var output_file = get_output_path(abs_input)

    # Check if we can skip compilation (incremental build)
    var force_build = false
    if force != null {
        force_build = force
    }

    var can_skip = false
    if !force_build {
        if fileexists(output_file) {
            var out_stat = filestat(output_file)
            if out_stat {
                can_skip = true
                for dep_path of deps {
                    var dep_stat = filestat(dep_path)
                    if dep_stat {
                        if dep_stat.modifiedat > out_stat.modifiedat {
                            can_skip = false
                            break
                        }
                    }
                }
            }
        }
    }

    if can_skip {
        print("Build up-to-date: %s", output_file)
        return { ok: true, output: output_file }
    }

    // Load runtime once
    var runtime_js = read_runtime()

    var rebuild_needed = true
    var compiled_map = {}
    var ok = true
    var heal_attempts = 0
    var max_heal_attempts = 2

    while rebuild_needed {
        rebuild_needed = false
        if cfg != null {
            cfg.was_healed = false
        }

        compiled_map = {}
        var global_user_tasks = {}
        ok = true

        // First pass: prescan ALL files for task names (forward references)
        for dep_path of deps {
            var raw = fileread(dep_path)
            var content = strip_comments(raw)
            var tasks = prescan_tasks(content)
            @{ Object.assign(global_user_tasks, tasks); @}
        }

        // Second pass: compile each file
        for dep_path of deps {
            var js = compile_file(dep_path, runtime_js, global_user_tasks)
            if !js {
                // Local compilation failed — try AI fallback
                if strict || !cfg {
                    print("\x1b[1;31mStrict Mode Error: Local compilation failed on %s. AI compilation is disabled.\x1b[0m", dep_path)
                    ok = false
                    break
                }
                var cache_path = get_cache_path(dep_path)
                var ai_ok = ai_compile_file(cfg, dep_path, cache_path)
                if !ai_ok {
                    ok = false
                    break
                }
                // Read back what AI wrote
                js = fileread(cache_path)
            }
            compiled_map[dep_path] = js
            print("Compiled: %s", dep_path)
        }

        if !ok {
            return { ok: false }
        }

        if cfg != null && cfg.was_healed {
            heal_attempts = heal_attempts + 1
            if heal_attempts > max_heal_attempts {
                print("\x1b[1;31mError: Exceeded maximum AI healing attempts (%d). Aborting compilation to prevent infinite loops.\x1b[0m", max_heal_attempts)
                return { ok: false }
            }
            rebuild_needed = true
            // Reload dependencies since a file was healed and may have new include directives
            deps = get_all_dependencies(abs_input, null)
            continue
        }

        // Bundle
        bresult = build(abs_input, output_file, compiled_map)

        if !bresult.ok {
            if strict || !cfg {
                return bresult
            }
            // Try to find which file caused the esbuild error
            var failed_file = null
            var err_msg = bresult.error
            @{
                const m = /\.omniflux_cache\/([^\s:]+)\.js/.exec(err_msg);
                if (m) {
                    const rel = m[1] + '.of';
                    // Find matching absolute path in compiled_map keys
                    for (const abs_path of Object.keys(compiled_map)) {
                        if (abs_path.endsWith(rel)) {
                            failed_file = abs_path;
                            break;
                        }
                    }
                }
            @}
            if !failed_file {
                // Fallback to main input file if we couldn't parse the error
                failed_file = abs_input
            }

            print("\x1b[1;33mBundling failed due to JS syntax error. Falling back to AI Compiler for %s...\x1b[0m", failed_file)
            var cache_path = get_cache_path(failed_file)
            if fileexists(cache_path) {
                filedelete(cache_path)
            }
            var ai_ok = ai_compile_file(cfg, failed_file, cache_path, bresult.error)
            if !ai_ok {
                return bresult
            }

            if cfg != null && cfg.was_healed {
                heal_attempts = heal_attempts + 1
                if heal_attempts > max_heal_attempts {
                    print("\x1b[1;31mError: Exceeded maximum AI healing attempts (%d). Aborting compilation to prevent infinite loops.\x1b[0m", max_heal_attempts)
                    return { ok: false }
                }
                rebuild_needed = true
                deps = get_all_dependencies(abs_input, null)
                continue
            }

            // Update compiled_map with the AI generated JS
            compiled_map[failed_file] = fileread(cache_path)
            // Re-bundle
            bresult = build(abs_input, output_file, compiled_map)
        }
    }

    if bresult.ok {
        var end_time = 0
        @{ end_time = Date.now(); @}
        var duration = end_time - start_time
        print("Build Successful -> %s (%dms)", output_file, duration)
    }
    return bresult
}

// ---------------------------------------------------------------------------
// run_output: execute the built binary
// ---------------------------------------------------------------------------
define task run_output(output_file, run_args) {
    print("Running: %s", output_file)
    print("----------------------------------------")
    @{
        const { spawn } = require('child_process');
        const child = spawn(output_file, run_args || [], { stdio: ['inherit', 'pipe', 'pipe'] });
        let output = '';

        child.stdout.on('data', (data) => {
            process.stdout.write(data);
            output += data.toString();
        });

        child.stderr.on('data', (data) => {
            process.stderr.write(data);
            output += data.toString();
        });

        return new Promise((resolve) => {
            child.on('close', (code, signal) => {
                if (code !== 0 || signal) {
                    console.log("Process exited with code " + code + (signal ? " due to signal " + signal : ""));
                }
                console.log("----------------------------------------");
                resolve(output);
            });
            child.on('error', (err) => {
                console.error("Failed to start process:", err.message);
                console.log("----------------------------------------");
                resolve(output);
            });
        });
    @}
}

// ---------------------------------------------------------------------------
// restart_watch_process: kill previous background watch process and spawn a new one with inherited stdio
// ---------------------------------------------------------------------------
define task restart_watch_process(output_file) {
    @{
        if (global.__running_watch_child) {
            try {
                global.__running_watch_child.kill('SIGTERM');
            } catch (e) {}
            global.__running_watch_child = null;
        }
        const { spawn } = require('child_process');
        global.__running_watch_child = spawn(output_file, [], { stdio: 'inherit' });
    @}
}

// ---------------------------------------------------------------------------
// watch_loop: rebuild and restart on file changes
// ---------------------------------------------------------------------------
define task watch_loop(input_file, compile_only) {
    var last_build_ok = false
    var output_file = ""

    var result = build_once(input_file, compile_only, false, null)
    if result.ok {
        last_build_ok = true
        output_file = result.output
        if !compile_only {
            restart_watch_process(output_file)
        }
    }

    print("Watching for changes... (Press Ctrl+C to stop)")

    var abs_input = pathresolve(input_file)
    var deps = get_all_dependencies(abs_input, null)

    // Record current modification times
    var mod_times = {}
    for dep_path of deps {
        var stat = filestat(dep_path)
        if stat {
            mod_times[dep_path] = stat.modifiedat
        }
    }

    while true {
        wait 1 second

        // Re-check all dependency modification times
        var changed = false
        for dep_path of deps {
            if !fileexists(dep_path) {
                changed = true
                break
            }
            var stat2 = filestat(dep_path)
            if stat2 && mod_times[dep_path] && stat2.modifiedat > mod_times[dep_path] {
                changed = true
                break
            }
        }

        if changed {
            print("\nChange detected. Rebuilding...")
            var new_result = build_once(input_file, compile_only, false, null)
            if new_result.ok {
                output_file = new_result.output
                if !compile_only {
                    restart_watch_process(output_file)
                }
            } else {
                print("Rebuild failed. Waiting for fixes...")
            }

            // Refresh dependency list and mod times
            deps = get_all_dependencies(abs_input, null)
            mod_times = {}
            for dep_path2 of deps {
                var stat3 = filestat(dep_path2)
                if stat3 {
                    mod_times[dep_path2] = stat3.modifiedat
                }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// watch_loop_ai: rebuild and restart on file changes (AI-aware)
// ---------------------------------------------------------------------------
define task watch_loop_ai(input_file, compile_only, strict, cfg) {
    var output_file = ""

    var result = build_once(input_file, compile_only, strict, cfg)
    if result.ok {
        output_file = result.output
        if !compile_only {
            restart_watch_process(output_file)
        }
    }

    print("Watching for changes... (Press Ctrl+C to stop)")

    var abs_input = pathresolve(input_file)
    var deps = get_all_dependencies(abs_input, null)

    var mod_times = {}
    for dep_path of deps {
        var stat = filestat(dep_path)
        if stat {
            mod_times[dep_path] = stat.modifiedat
        }
    }

    while true {
        wait 1 second

        var changed = false
        for dep_path of deps {
            if !fileexists(dep_path) {
                changed = true
                break
            }
            var stat2 = filestat(dep_path)
            if stat2 && mod_times[dep_path] && stat2.modifiedat > mod_times[dep_path] {
                changed = true
                break
            }
        }

        if changed {
            print("\nChange detected. Rebuilding...")
            var new_result = build_once(input_file, compile_only, strict, cfg)
            if new_result.ok {
                output_file = new_result.output
                if !compile_only {
                    restart_watch_process(output_file)
                }
            } else {
                print("Rebuild failed. Waiting for fixes...")
            }

            deps = get_all_dependencies(abs_input, null)
            mod_times = {}
            for dep_path2 of deps {
                var stat3 = filestat(dep_path2)
                if stat3 {
                    mod_times[dep_path2] = stat3.modifiedat
                }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------
on start {
    var cli = parse_args(args)

    if cli.help {
        print_usage()
        exit(0)
    }

    if cli.version {
        print("OmniFlux version " + $VERSION)
        exit(0)
    }

    if cli.setup {
        run_wizard()
        exit(0)
    }

    // Load or create config
    var cfg = null
    if !config_exists() {
        if cli.strict {
            cfg = { api_key: "" }
        } else {
            cfg = run_wizard()
        }
    } else {
        cfg = config_load()
    }

    cfg.verbose = cli.verbose

    // No input file → interactive chat mode
    if cli.input_file == "" {
        interactive_chat(cfg)
        exit(0)
    }

    if cli.watch {
        watch_loop_ai(cli.input_file, cli.compile_only, cli.strict, cfg)
    } else {
        var result = build_once(cli.input_file, cli.compile_only, cli.strict, cfg, cli.force)
        if !result.ok {
            exit(1)
        }
        if !cli.compile_only {
            var run_out = run_output(result.output, cli.run_args)
            // If the program crashed with a ReferenceError (e.g. typo in variable name),
            // rebuild using AI and run again
            if run_out && match(run_out, "/ReferenceError|TypeError|is not defined|Cannot read properties|is not a function/") && !cli.strict {
                print("\x1b[1;33mRuntime error detected. Falling back to AI Compiler...\x1b[0m")
                var abs_input2 = pathresolve(cli.input_file)
                var deps2 = get_all_dependencies(abs_input2, null)
                // Delete cache so build_once recompiles fresh via AI
                for dep_path2 of deps2 {
                    var cache_path2 = get_cache_path(dep_path2)
                    if fileexists(cache_path2) {
                        filedelete(cache_path2)
                    }
                    ai_compile_file(cfg, dep_path2, cache_path2, run_out)
                }
                
                if cfg != null && cfg.was_healed {
                    var rebuild_res = build_once(cli.input_file, cli.compile_only, cli.strict, cfg, true)
                    if rebuild_res.ok {
                        run_output with rebuild_res.output, cli.run_args
                    }
                } else {
                    // Bundle the AI-compiled files and run
                    var abs_inp2 = pathresolve(cli.input_file)
                    var out_path2 = get_output_path(abs_inp2)
                    var ai_deps = get_all_dependencies(abs_inp2, null)
                    var ai_map = {}
                    for ai_dep of ai_deps {
                        var ai_cache = get_cache_path(ai_dep)
                        ai_map[ai_dep] = fileread(ai_cache)
                    }
                    var result2 = build(abs_inp2, out_path2, ai_map)
                    if result2.ok {
                        run_output with result2.output, cli.run_args
                    }
                }
            }
        }
        exit(0)
    }
}
