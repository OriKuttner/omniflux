{
  "name": "omniflux-support",
  "displayName": "OmniFlux Language Support",
  "description": "Syntax highlighting and snippets for the OmniFlux Programming Language.",
  "version": "1.0.0",
  "publisher": "omniflux",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [{
      "id": "omniflux",
      "aliases": ["OmniFlux", "omniflux"],
      "extensions": [".of"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "omniflux",
      "scopeName": "source.omniflux",
      "path": "./syntaxes/omniflux.tmLanguage.json"
    }],
    "snippets": [{
      "language": "omniflux",
      "path": "./snippets/snippets.json"
    }]
  }
}
