{
  "Listen on Port": {
    "prefix": "listen",
    "body": [
      "listen on port ${1:3000}"
    ],
    "description": "Initialize web server on port"
  },
  "GET Handler": {
    "prefix": "get",
    "body": [
      "when receiving GET request to \"${1:/api/route}\":",
      "    ${0:// Handle request}"
    ],
    "description": "Create a GET route handler"
  },
  "POST Handler": {
    "prefix": "post",
    "body": [
      "when receiving POST request to \"${1:/api/route}\":",
      "    const ${2:param} = ${2:param} from body",
      "    ${0:// Handle request}"
    ],
    "description": "Create a POST route handler"
  },
  "Timer Loop": {
    "prefix": "every",
    "body": [
      "every ${1:10} ${2|seconds,minutes,hours|} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a repeating timer loop"
  },
  "Delay": {
    "prefix": "wait",
    "body": [
      "wait ${1:2} ${2|seconds,minutes,hours|}"
    ],
    "description": "Wait/Delay execution"
  },
  "Database Select": {
    "prefix": "dbselect",
    "body": [
      "const ${1:results} = dbselect(\"${2:collection}\", { ${3:field}: \"${4:value}\" })"
    ],
    "description": "Select documents from local JSON database"
  },
  "Database Insert": {
    "prefix": "dbinsert",
    "body": [
      "dbinsert(\"${1:collection}\", { ${2:key}: \"${3:value}\" })"
    ],
    "description": "Insert document into local JSON database"
  },
  "Cache Set": {
    "prefix": "cacheset",
    "body": [
      "cacheset(\"${1:key}\", ${2:value}, ${3:3600})"
    ],
    "description": "Cache a value in Redis with TTL"
  },
  "On Start": {
    "prefix": "start",
    "body": [
      "on start {",
      "    ${0}",
      "}"
    ],
    "description": "Code executes immediately on start"
  },
  "MySQL Connect": {
    "prefix": "mysqlconnect",
    "body": [
      "mysqlconnect({",
      "    host: \"${1:127.0.0.1}\",",
      "    port: ${2:3306},",
      "    user: \"${3:root}\",",
      "    password: \"${4}\",",
      "    database: \"${5:database_name}\"",
      "})"
    ],
    "description": "Establish connection pool to MySQL database"
  },
  "MySQL Query": {
    "prefix": "mysqlquery",
    "body": [
      "var ${1:rows} = mysqlquery(\"${2:SELECT * FROM table}\")"
    ],
    "description": "Execute a SQL query on MySQL database"
  },
  "Get Object Keys": {
    "prefix": "keys",
    "body": [
      "keys(${1:obj})"
    ],
    "description": "Get an array of the keys of an object"
  }
}
